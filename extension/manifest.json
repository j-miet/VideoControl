{
  "description": "Control HTML5 video playback speed",
  "manifest_version": 3,
  "name": "VideoControl",
  "version": "1.0",

  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "browser_specific_settings": {
    "gecko": {
      "id": "videocontrol@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_popup": "popup/ui.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/control.js"],
      "run_at": "document_idle"
    }
  ]
}
