{
  "name": "VideoControl",
  "short_name": "VideoControl",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Control HTML5 video playback speed, forward/backward custom lengths and take screenshots of videos on any website",
  "homepage_url": "https://github.com/j-miet/VideoControl",
  "permissions": ["storage", "clipboardWrite", "tabs"],

  "browser_specific_settings": {
    "gecko": {
      "id": "videocontrol@mozilla.org"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "VideoControl",
    "default_popup": "popup/ui.html"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["scripts/control.js"],
      "run_at": "document_idle"
    }
  ]
}
