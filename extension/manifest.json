{
  "description": "Basic desktop HTML5 video playback manipulation: change speed individually per video, forward/backward custom lengths and copy video frames to clipboard.",
  "manifest_version": 3,
  "name": "VideoControl",
  "version": "1.0",

  "permissions": ["storage", "clipboardWrite", "tabs"],

  "browser_specific_settings": {
    "gecko": {
      "id": "videocontrol@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_title": "VideoControl",
    "default_popup": "popup/ui.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/control.js"],
      "run_at": "document_idle"
    }
  ]
}
